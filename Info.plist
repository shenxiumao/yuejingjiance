<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 应用基本信息 -->
    <key>CFBundleDevelopmentRegion</key>
    <string>zh-Hans</string>
    
    <key>CFBundleDisplayName</key>
    <string>月经助手</string>
    
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    
    <key>CFBundleShortVersionString</key>
    <string>2.0.0</string>
    
    <key>CFBundleVersion</key>
    <string>200</string>
    
    <key>LSRequiresIPhoneOS</key>
    <true/>
    
    <!-- 应用本地化 -->
    <key>CFBundleLocalizations</key>
    <array>
        <string>zh-Hans</string>
        <string>zh-Hant</string>
        <string>en</string>
    </array>
    
    <!-- 界面设置 -->
    <key>UILaunchScreen</key>
    <dict>
        <key>UIColorName</key>
        <string>LaunchScreenBackground</string>
        <key>UIImageName</key>
        <string>LaunchScreenIcon</string>
    </dict>
    
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>armv7</string>
        <string>healthkit</string>
    </array>
    
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleDefault</string>
    
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <true/>
    
    <!-- 隐私权限说明 -->
    <key>NSHealthShareUsageDescription</key>
    <string>我们可以读取您的健康数据，以便更准确地追踪您的月经周期和症状。</string>
    
    <key>NSHealthUpdateUsageDescription</key>
    <string>我们可以将您的月经周期和症状数据写入健康 App，以便您统一管理健康信息。</string>
    
    <key>NSUserNotificationsUsageDescription</key>
    <string>我们可以向您发送月经和排卵期提醒，帮助您更好地管理生理周期。</string>
    
    <key>NSFaceIDUsageDescription</key>
    <string>使用面容 ID 保护您的隐私数据，确保只有您能访问应用。</string>
    
    <!-- iCloud 同步 -->
    <key>NSUbiquitousContainers</key>
    <dict>
        <key>iCloud.com.example.yuejingjiance</key>
        <dict>
            <key>NSUbiquitousContainerIsDocumentScopePublic</key>
            <true/>
            <key>NSUbiquitousContainerName</key>
            <string>月经助手数据</string>
            <key>NSUbiquitousContainerSupportedFolderLevels</key>
            <string>Any</string>
        </dict>
    </dict>
    
    <!-- App Groups 用于数据共享 -->
    <key>com.apple.developer.app-groups</key>
    <array>
        <string>group.com.example.yuejingjiance</string>
    </array>
    
    <!-- 深色模式支持 -->
    <key>UIUserInterfaceStyle</key>
    <string>Automatic</string>
    
    <!-- 多任务支持 -->
    <key>UIRequiresPersistentWiFi</key>
    <false/>
    
    <!-- 文件访问 -->
    <key>UISupportsDocumentBrowser</key>
    <true/>
    
    <!-- 辅助功能 -->
    <key>UIAccessibility</key>
    <dict>
        <key>UIAccessibilityVoiceOverCaptionPreferred</key>
        <true/>
    </dict>
    
    <!-- 隐私政策 -->
    <key>NSPrivacyPolicyURL</key>
    <string>https://example.com/privacy</string>
    
    <key>NSPrivacyPolicyText</key>
    <string>我们非常重视您的隐私。您的所有健康数据都存储在本地设备上，不会上传到任何服务器。</string>
</dict>
</plist>
